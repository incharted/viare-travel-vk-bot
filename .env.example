APP_ENV=dev
VK_TOKEN=your_token_here

# VK ID пользователя с правами администратора.
# Если администраторов несколько, укажите ID через запятую.
ADMIN_IDS=

# VK ID менеджеров, которые могут работать с заявками.
# Администратор автоматически получает права менеджера.
MANAGER_IDS=

DB_PATH=./data/bot.sqlite3
LOG_LEVEL=INFO
LOG_FILE=./data/bot.log

# Базовая защита от слишком частых сообщений.
RATE_LIMIT_COUNT=8
RATE_LIMIT_WINDOW_SEC=10

# Проверка SSL для запросов к VK и внешним API.
VK_SSL_VERIFY=1

# Настройки внешнего поиска туров.
EXTERNAL_TOURS_ENABLED=1
TRAVELATA_BASE_URL=https://api-gateway.travelata.ru
TRAVELATA_DEPARTURE_CITY_ID=2
TRAVELATA_TIMEOUT_SEC=12
TRAVELATA_MAX_RESULTS=5

# Необязательный путь к сертификату, если используется корпоративный прокси.
# CA_BUNDLE_PATH=C:/absolute/path/to/ca_bundle.pem
