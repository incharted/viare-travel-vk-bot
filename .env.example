APP_ENV=dev
VK_TOKEN=your_token_here
ADMIN_IDS=
# Put your VK user ID here to unlock admin commands, example:
# ADMIN_IDS=123456789
MANAGER_IDS=
# Optional VK user IDs for managers, example:
# MANAGER_IDS=111111111,222222222
DB_PATH=./data/bot.sqlite3
LOG_LEVEL=DEBUG
LOG_FILE=./data/bot.log
RATE_LIMIT_COUNT=8
RATE_LIMIT_WINDOW_SEC=10
VK_SSL_VERIFY=1
EXTERNAL_TOURS_ENABLED=1
TRAVELATA_BASE_URL=https://api-gateway.travelata.ru
# Example departure city id from official Travelata docs query.
TRAVELATA_DEPARTURE_CITY_ID=2
TRAVELATA_TIMEOUT_SEC=12
TRAVELATA_MAX_RESULTS=5
# Optional custom CA bundle for corporate proxy certificates
# CA_BUNDLE_PATH=/absolute/path/to/ca_bundle.pem
